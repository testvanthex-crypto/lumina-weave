# Core secrets
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32
DATABASE_URL=mysql://user:password@host:3306/lumina

# OAuth (optional, required for Continue with Google button)
VITE_APP_ID=your-app-id
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.com
OAUTH_SERVER_URL=https://your-oauth-portal.com

# Admin bootstrap (optional)
OWNER_OPEN_ID=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Runtime
NODE_ENV=production
PORT=3000
